// Lalela Platform — PostgreSQL Schema
// Naming convention: Prisma fields = camelCase, DB columns = snake_case via @map/@@map

generator client {
  provider = "prisma-client-js"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// USERS
// =============================================
model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  name                    String
  phone                   String?   @unique
  passwordHash            String?   @map("password_hash")
  emailVerified           Boolean   @default(false) @map("email_verified")
  phoneVerified           Boolean   @default(false) @map("phone_verified")
  profileCompleted        Boolean   @default(false) @map("profile_completed")
  communityCreated        Boolean   @default(false) @map("community_created")
  onboardingComplete      Boolean   @default(false) @map("onboarding_complete")
  licenseStatus           String    @default("UNLICENSED") @map("license_status")
  licenseExpiry           DateTime? @map("license_expiry")
  licenseType             String?   @map("license_type")
  autoRenew               Boolean   @default(false) @map("auto_renew")
  accessType              String?   @map("access_type")
  expiryDate              DateTime? @map("expiry_date")
  memberExpiryDate        DateTime? @map("member_expiry_date")
  status                  String    @default("ACTIVE")
  role                    String    @default("user")
  profileImage            String?   @map("profile_image")
  fcmToken                String?   @map("fcm_token")
  pushToken               String?   @map("push_token")
  pushPlatform            String?   @map("push_platform")
  firstName               String?   @map("first_name")
  lastName                String?   @map("last_name")
  mobileNumber            String?   @map("mobile_number")
  address                 String?
  latitude                Float?
  longitude               Float?
  locationSharing         Boolean   @default(false) @map("location_sharing")
  isSecurityMember        Boolean   @default(false) @map("is_security_member")
  emergencyLocationOptIn  Boolean   @default(false) @map("emergency_location_opt_in")
  lastCommunityId         String?   @map("last_community_id")
  agreedToTerms           Boolean   @default(false) @map("agreed_to_terms")
  marketingConsent        Boolean   @default(false) @map("marketing_consent")
  profileVisibility       String?   @map("profile_visibility")
  piiVisibility           String?   @map("pii_visibility")
  lastPasswordChanged     DateTime? @map("last_password_changed")
  securityScore           String?   @map("security_score")
  notificationPreferences Json?     @map("notification_preferences")
  twoFactorEnabled        Boolean   @default(false) @map("two_factor_enabled")
  twoFactorMethod         String?   @map("two_factor_method")
  loginAlertsEnabled      Boolean   @default(true) @map("login_alerts_enabled")
  pendingInviteCode       String?   @map("pending_invite_code")
  deleted                 Boolean   @default(false)
  deletedAt               DateTime? @map("deleted_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  communities         CommunityMember[]
  businesses          Business[]
  posts               Post[]
  messages            Message[]
  reports             Report[]              @relation("Reporter")
  ownedCommunities    Community[]           @relation("CommunityOwner")
  sessions            UserSession[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  emailTokens         EmailVerificationToken[]
  otpCodes            OtpCode[]
  passwordResetTokens PasswordResetToken[]
  charitySuggestions  CharitySuggestion[]
  sentInvitations     CommunityInvitation[] @relation("InvitedBy")
  receivedInvitations CommunityInvitation[] @relation("InvitedUser")
  inviteLinks         CommunityInviteLink[]
  conversations       ConversationParticipant[]
  licenses            License[]

  @@index([email])
  @@index([phone])
  @@map("users")
}

// =============================================
// AUTH TOKENS
// =============================================
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique @default(cuid())
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique @default(cuid())
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  phone     String
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@map("otp_codes")
}

model BlacklistedEmail {
  email       String   @id
  deletedAt   DateTime @default(now()) @map("deleted_at")
  originalUid String?  @map("original_uid")

  @@map("blacklisted_emails")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  device       String?
  ip           String?
  location     String?
  lastActive   DateTime @default(now()) @map("last_active")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@map("user_sessions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  message   String
  ip        String?
  status    String   @default("success")
  metadata  Json?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("audit_logs")
}

// =============================================
// COMMUNITIES
// =============================================
model Community {
  id                       String    @id @default(cuid())
  name                     String
  description              String?
  ownerId                  String    @map("owner_id")
  type                     String    @default("TRIAL")
  status                   String    @default("ACTIVE")
  isEmergencyMode          Boolean   @default(false) @map("is_emergency_mode")
  coverageLat              Float?    @map("coverage_lat")
  coverageLng              Float?    @map("coverage_lng")
  coverageRadius           Float?    @map("coverage_radius")
  coverageLocation         String?   @map("coverage_location")
  enabledCategories        String[]  @default([]) @map("enabled_categories")
  trialEndDate             DateTime? @map("trial_end_date")
  licenseId                String?   @map("license_id")
  licenseExpiry            DateTime? @map("license_expiry")
  activeEmergencyId        String?   @map("active_emergency_id")
  onboardingStepsCompleted String[]  @default([]) @map("onboarding_steps_completed")
  guidedSetupRequired      Boolean   @default(true) @map("guided_setup_required")
  isPublic                 Boolean   @default(true) @map("is_public")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  owner              User               @relation("CommunityOwner", fields: [ownerId], references: [id])
  members            CommunityMember[]
  posts              Post[]
  messages           Message[]
  charities          Charity[]
  charitySuggestions CharitySuggestion[]
  reports            Report[]
  invitations        CommunityInvitation[]
  inviteLinks        CommunityInviteLink[]
  memberLocations    MemberLocation[]
  securityLocations  SecurityLocation[]
  moderationLogs     ModerationLog[]
  securityEvents     SecurityEvent[]
  licenses           License[]

  @@index([ownerId])
  @@index([status])
  @@map("communities")
}

// =============================================
// COMMUNITY MEMBERS
// =============================================
model CommunityMember {
  communityId            String    @map("community_id")
  userId                 String    @map("user_id")
  role                   String    @default("MEMBER")
  joinedAt               DateTime  @default(now()) @map("joined_at")
  licenseExpiry          DateTime? @map("license_expiry")
  status                 String    @default("ACTIVE")
  isSecurityMember       Boolean   @default(false) @map("is_security_member")
  locationSharingEnabled Boolean   @default(true) @map("location_sharing_enabled")
  name                   String?
  image                  String?
  email                  String?
  emergencyLocationOptIn Boolean   @default(false) @map("emergency_location_opt_in")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([communityId, userId])
  @@index([userId])
  @@map("community_members")
}

model MemberLocation {
  id          String   @id @default(cuid())
  communityId String   @map("community_id")
  userId      String   @map("user_id")
  name        String?
  image       String?
  role        String   @default("MEMBER")
  latitude    Float
  longitude   Float
  timestamp   DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@map("member_locations")
}

model SecurityLocation {
  id          String   @id @default(cuid())
  communityId String   @map("community_id")
  userId      String   @map("user_id")
  name        String?
  image       String?
  latitude    Float
  longitude   Float
  timestamp   DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@map("security_locations")
}

// =============================================
// MESSAGES (Chat)
// =============================================
model Message {
  id             String   @id @default(cuid())
  communityId    String?  @map("community_id")
  conversationId String?  @map("conversation_id")
  userId         String?  @map("user_id")
  content        String?
  imageUrl       String?  @map("image_url")
  attachmentUrl  String?  @map("attachment_url")
  fileName       String?  @map("file_name")
  messageType    String   @default("text") @map("message_type")
  replyToId      String?  @map("reply_to_id")
  status         String   @default("sent")
  readBy         String[] @default([]) @map("read_by")
  createdAt      DateTime @default(now()) @map("created_at")

  community    Community?    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id])
  replyTo      Message?      @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]     @relation("MessageReplies")

  @@index([communityId, createdAt])
  @@index([conversationId])
  @@map("messages")
}

// =============================================
// POSTS / LISTINGS / NOTICES
// =============================================
model Post {
  id                   String    @id @default(cuid())
  communityId          String    @map("community_id")
  authorId             String    @map("author_id")
  type                 String
  title                String
  description          String
  category             String
  subtype              String?
  urgency              String    @default("LOW")
  urgencyLevel         String?   @map("urgency_level")
  price                Float?
  communityPrice       Float?    @map("community_price")
  publicPrice          Float?    @map("public_price")
  charityAmount        Float?    @map("charity_amount")
  charityPercentage    Float?    @map("charity_percentage")
  imageUrl             String?   @map("image_url")
  postsImage           String?   @map("posts_image")
  isPublic             Boolean   @default(false) @map("is_public")
  isCommunityPick      Boolean   @default(false) @map("is_community_pick")
  isCharity            Boolean   @default(false) @map("is_charity")
  charityId            String?   @map("charity_id")
  authorName           String?   @map("author_name")
  authorRole           String?   @map("author_role")
  authorImage          String?   @map("author_image")
  locationName         String?   @map("location_name")
  latitude             Float?
  longitude            Float?
  source               String?
  status               String    @default("active")
  rejectionReason      String?   @map("rejection_reason")
  changesRequestedNote String?   @map("changes_requested_note")
  expiresAt            DateTime? @map("expires_at")
  expiredAt            DateTime? @map("expired_at")
  deletedAt            DateTime? @map("deleted_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])

  @@index([communityId, createdAt])
  @@index([authorId])
  @@index([status])
  @@map("posts")
}

// =============================================
// CHARITIES & SUGGESTIONS
// =============================================
model Charity {
  id                   String   @id @default(cuid())
  communityId          String   @map("community_id")
  name                 String
  description          String?
  category             String?
  percentage           Float    @default(0)
  status               String   @default("ACTIVE")
  urgency              String?
  fundraisingGoal      Float?   @map("fundraising_goal")
  raisedAmount         Float    @default(0) @map("raised_amount")
  imageUrl             String?  @map("image_url")
  locationName         String?  @map("location_name")
  latitude             Float?
  longitude            Float?
  isVerified           Boolean  @default(false) @map("is_verified")
  isFeatured           Boolean  @default(false) @map("is_featured")
  tags                 String[] @default([])
  linkedBusinessIds    String[] @default([]) @map("linked_business_ids")
  campaignCompleted    Boolean  @default(false) @map("campaign_completed")
  isApprovedSuggestion Boolean  @default(false) @map("is_approved_suggestion")
  suggestedById        String?  @map("suggested_by_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  community          Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  charitySuggestions CharitySuggestion[]

  @@index([communityId])
  @@map("charities")
}

model CharitySuggestion {
  id                      String   @id @default(cuid())
  communityId             String   @map("community_id")
  charityId               String?  @map("charity_id")
  suggestedBy             String   @map("suggested_by")
  name                    String
  description             String?
  reason                  String?
  suggestedDonationAmount Float?   @map("suggested_donation_amount")
  website                 String?
  status                  String   @default("pending")
  adminFeedback           String?  @map("admin_feedback")
  createdAt               DateTime @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  charity   Charity?  @relation(fields: [charityId], references: [id])
  user      User      @relation(fields: [suggestedBy], references: [id])

  @@index([communityId])
  @@map("charity_suggestions")
}

// =============================================
// BUSINESSES
// =============================================
model Business {
  id           String   @id @default(cuid())
  ownerId      String   @map("owner_id")
  name         String
  category     String
  description  String?
  latitude     Float?
  longitude    Float?
  address      String?
  phone        String?
  website      String?
  rating       Float?
  imageUrl     String?  @map("image_url")
  charityId    String?  @map("charity_id")
  communityIds String[] @default([]) @map("community_ids")
  status       String   @default("ACTIVE")
  source       String   @default("MEMBER")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([status])
  @@map("user_businesses")
}

// =============================================
// REPORTS
// =============================================
model Report {
  id          String   @id @default(cuid())
  communityId String   @map("community_id")
  reporterId  String   @map("reporter_id")
  targetId    String   @map("target_id")
  targetType  String   @map("target_type")
  reason      String
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id])
  reporter  User      @relation("Reporter", fields: [reporterId], references: [id])

  @@map("reports")
}

// =============================================
// INVITATIONS
// =============================================
model CommunityInvitation {
  id               String    @id @default(cuid())
  communityId      String    @map("community_id")
  invitedById      String    @map("invited_by_id")
  invitedUserId    String?   @map("invited_user_id")
  invitedEmail     String?   @map("invited_email")
  invitedByAdminId String?   @map("invited_by_admin_id")
  role             String    @default("MEMBER")
  status           String    @default("pending")
  createdAt        DateTime  @default(now()) @map("created_at")
  expiresAt        DateTime? @map("expires_at")

  community   Community @relation(fields: [communityId], references: [id])
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id])
  invitedUser User?     @relation("InvitedUser", fields: [invitedUserId], references: [id])

  @@index([communityId])
  @@index([invitedUserId])
  @@map("community_invitations")
}

model CommunityInviteLink {
  id          String    @id @default(cuid())
  communityId String    @map("community_id")
  createdBy   String    @map("created_by")
  code        String    @unique @default(cuid())
  role        String    @default("MEMBER")
  uses        Int       @default(0)
  maxUses     Int?      @map("max_uses")
  active      Boolean   @default(true)
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  creator   User      @relation(fields: [createdBy], references: [id])

  @@index([code])
  @@index([communityId])
  @@map("community_invite_links")
}

// =============================================
// CONVERSATIONS & MESSAGES
// =============================================
model Conversation {
  id            String    @id @default(cuid())
  type          String    @default("direct")
  listingId     String?   @map("listing_id")
  noticeId      String?   @map("notice_id")
  communityId   String?   @map("community_id")
  lastMessage   String?   @map("last_message")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@index([communityId])
  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  unreadCount    Int      @default(0) @map("unread_count")
  joinedAt       DateTime @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

// =============================================
// NOTIFICATIONS
// =============================================
model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

// =============================================
// LICENSES
// =============================================
model License {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  communityId String?   @map("community_id")
  type        String
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community? @relation(fields: [communityId], references: [id])

  @@index([userId])
  @@map("licenses")
}

// =============================================
// MODERATION LOGS
// =============================================
model ModerationLog {
  id          String   @id @default(cuid())
  communityId String   @map("community_id")
  moderatorId String   @map("moderator_id")
  action      String
  targetId    String   @map("target_id")
  targetType  String   @map("target_type")
  notes       String?
  timestamp   DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@map("moderation_logs")
}

// =============================================
// SECURITY EVENTS
// =============================================
model SecurityEvent {
  id          String   @id @default(cuid())
  communityId String   @map("community_id")
  type        String
  severity    String
  description String
  resolved    Boolean  @default(false)
  metadata    Json?
  timestamp   DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@map("security_events")
}
