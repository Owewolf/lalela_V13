{
  "name": "lalela",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --dev-client --host lan",
    "start:localhost": "expo start --dev-client --host localhost",
    "dev:iphone": "bash -lc 'bash start-dev.sh >/tmp/lalela-start-dev.log 2>&1 & sleep 8; EXPO_PUBLIC_API_URL=https://api.wolfslair.cc/api expo start --dev-client --host lan'",
    "dev:stop": "bash -lc 'pkill -f \"expo start\" 2>/dev/null || true; pkill -f \"tsx watch server/index.ts\" 2>/dev/null || true; pkill -f \"cloudflared tunnel run\" 2>/dev/null || true'",
    "dev:iphone:clean": "bash -lc 'npm run -s dev:stop; bash start-dev.sh >/tmp/lalela-start-dev.log 2>&1 & sleep 8; EXPO_PUBLIC_API_URL=https://api.wolfslair.cc/api expo start --dev-client --host lan'",
    "tunnel": "expo start --dev-client --tunnel",
    "android": "JAVA_HOME=/var/lib/snapd/snap/android-studio/209/jbr BROWSER=none expo run:android --port 8070",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "server": "tsx server/index.ts",
    "server:dev": "tsx watch server/index.ts",
    "build": "npx expo export --platform web",
    "lint": "tsc --noEmit && npm run -s lint:business-image-guard",
    "lint:business-image-guard": "node scripts/check-business-image-precedence.js",
    "lint:theme-guard": "node scripts/check-hardcoded-colors.js",
    "lint:card-guard": "node scripts/check-card-style-literals.js",
    "audit:theme-noncolor": "node scripts/check-noncolor-style-literals.js",
    "backfill:posts-image": "tsx scripts/backfill-posts-image-from-image-url.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "postinstall": "prisma generate && node scripts/patch-google-places.js && node scripts/patch-react-async-hook.js"
  },
  "dependencies": {
    "@expo-google-fonts/epilogue": "^0.4.2",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo/metro-runtime": "~6.1.2",
    "@google/genai": "^1.29.0",
    "@parse/node-apn": "^8.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@tanstack/query-async-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "@teovilla/react-native-web-maps": "^0.9.5",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "lucide-react-native": "^1.9.0",
    "minio": "^8.0.5",
    "multer": "^2.0.1",
    "nativewind": "^4.2.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-places-autocomplete": "^2.6.4",
    "react-native-maps": "1.20.1",
    "react-native-phone-number-input": "^2.1.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webrtc": "^124.0.0",
    "react-native-worklets": "0.5.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@config-plugins/react-native-webrtc": "^13.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "~19.1.0",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "babel-preset-expo": "~54.0.10",
    "prisma": "^7.8.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "expo-location": "~19.0.8"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-webrtc"
        ]
      }
    }
  },
  "private": true
}
