# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=*
API_BASE_URL=https://lalela.net/api

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:lalela@localhost:5432/lalela

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret

# ─── SMTP (mail.lalela.net) ───────────────────────────────────────────────────
SMTP_HOST=mail.lalela.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@lalela.net
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=Lalela <noreply@lalela.net>

# ─── SMS ──────────────────────────────────────────────────────────────────────
SMS_PROVIDER=africastalking          # or "twilio"

# Africa's Talking
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox                  # use "sandbox" for testing, your AT username for production
AT_SENDER_ID=LALELA                  # optional alphanumeric sender ID

# Twilio (fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Push Notifications ───────────────────────────────────────────────────────
# iOS (APNs) — get p8 key from Apple Developer Portal
APNS_KEY_PATH=/etc/lalela/apns.p8
APNS_KEY_ID=ABC123DEFG
APNS_TEAM_ID=TEAM123456
APNS_BUNDLE_ID=net.lalela.app
APNS_PRODUCTION=false                # set true for production

# Android (FCM HTTP v1) — Google service account with firebase.messaging scope
GOOGLE_SA_PATH=/etc/lalela/google-sa.json
FCM_PROJECT_ID=lalela-2e9d5

# ─── MinIO (object storage) ───────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=lalela
MINIO_SECRET_KEY=ChangeThisToStrongPassword123!
MINIO_PUBLIC_URL=https://storage.lalela.net

# ─── Gemini (AI search) ───────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Deep link (email verification redirect) ─────────────────────────────────
APP_DEEP_LINK=lalela://verified
